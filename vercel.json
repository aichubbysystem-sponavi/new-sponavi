{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["hnd1"],
  "crons": [
    {
      "path": "/api/cron/sync-reviews",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/execute-posts",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/auto-reply",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/monthly-analysis",
      "schedule": "0 1 1-5 * *"
    },
    {
      "path": "/api/cron/sync-shops",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/sync-search-keywords",
      "schedule": "0 20 5 * *"
    },
    {
      "path": "/api/cron/sync-performance",
      "schedule": "0 21 5 * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
